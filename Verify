name: Verify Human Identity

on:
  workflow_dispatch:
    inputs:
      agent_name:
        description: "Agent name"
        required: true
        default: "deus"
      agent_description:
        description: "Agent description"
        required: true
        default: "deus AI Agent"

jobs:
  verify:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repo
        uses: actions/checkout@v3

      - name: Setup Node.js
        uses: actions/setup-node@v3
        with:
          node-version: "20"

      - name: Step 1 - Install ClawHub skill
        run: npx --yes clawhub@latest install verified-agent-identity

      - name: Install script dependencies
        run: npm install --prefix scripts

      - name: Step 2 - Create new Ethereum Identity
        run: node scripts/createNewEthereumIdentity.js

      - name: Step 3 - Link Human to Agent
        env:
          AGENT_NAME: ${{ github.event.inputs.agent_name }}
          AGENT_DESCRIPTION: ${{ github.event.inputs.agent_description }}
        run: |
          node scripts/manualLinkHumanToAgent.js \
          --challenge "{\"name\":\"$AGENT_NAME\",\"description\":\"$AGENT_DESCRIPTION\"}"
